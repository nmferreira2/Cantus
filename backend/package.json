{
  "name": "@cantus/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Cantus API and Vanilla JavaScript SPA",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:import-repertoire": "node prisma/import-repertoire.js",
    "db:import-plans": "node prisma/import-plans.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
